TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id
STAFF_ROLE_ID=

# Public release: leave COMMAND_SCOPE as global and do not set GUILD_ID on Railway.
COMMAND_SCOPE=global

# Development only: set this and run npm run register:guild to update one server instantly.
# GUILD_ID=your_test_server_id

# Local only. On Railway, attach a Volume and the bot will use RAILWAY_VOLUME_MOUNT_PATH automatically.
# DATA_FILE=./data.json
